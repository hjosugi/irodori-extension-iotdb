{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.iotdb",
  "name": "IoTDB Connector",
  "version": "0.1.3",
  "publisher": "irodori",
  "description": "IoTDB Connector contributes the IoTDB database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-iotdb",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "iotdb.connector",
        "engine": "iotdb",
        "label": "IoTDB",
        "aliases": [
          "iotdb",
          "Apache IoTDB",
          "IoTDB"
        ],
        "defaultPort": 6667,
        "wire": "timeSeries",
        "module": "iotdb.driver",
        "features": [
          "metadata",
          "timeSeries",
          "timeBuckets",
          "latestValue",
          "queryTemplates",
          "visualization"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "iotdb",
            "wire": "timeSeries",
            "port": 6667,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 6667,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 6667
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 6667
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "userPassword",
              "label": "User/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "bearerToken",
              "label": "Bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "kerberos",
              "label": "Kerberos / GSSAPI",
              "kind": "kerberos",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "principal",
                  "label": "Principal",
                  "type": "string"
                },
                {
                  "id": "keytab",
                  "label": "Keytab",
                  "type": "path",
                  "secretPurpose": "privateKey"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "timeSeries",
            "iotdb"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "timeSeries"
          ],
          "inspiredBy": [
            "Apache IoTDB time-series hierarchy",
            "GROUP BY time",
            "ALIGN BY DEVICE",
            "FILL"
          ],
          "resultViews": [
            "timeChart",
            "table",
            "heatmap"
          ],
          "objectTypes": [
            "storageGroups",
            "devices",
            "measurements",
            "templates",
            "ttl"
          ],
          "workflows": [
            {
              "id": "time-device-query",
              "label": "Device aligned query",
              "description": "Compare measurements across devices.",
              "resultView": "timeChart",
              "templateIds": [
                "time-iotdb-group-by-device"
              ]
            },
            {
              "id": "time-gap-fill",
              "label": "Gap fill",
              "description": "Fill sparse telemetry windows for charting.",
              "resultView": "timeChart",
              "templateIds": [
                "time-iotdb-fill"
              ]
            },
            {
              "id": "time-latest",
              "label": "Latest telemetry",
              "description": "Inspect the newest values in a device subtree.",
              "resultView": "table",
              "templateIds": [
                "time-iotdb-latest"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "time-iotdb-group-by-device",
              "label": "GROUP BY time aligned by device",
              "language": "sql",
              "description": "Aggregate measurements per device over the last hour.",
              "insertText": "SELECT avg(temperature)\nFROM root.factory.**\nWHERE time >= now() - 1h\nGROUP BY ([now() - 1h, now()), 1m)\nALIGN BY DEVICE;",
              "parameters": [],
              "resultView": "timeChart"
            },
            {
              "id": "time-iotdb-fill",
              "label": "Fill missing windows",
              "language": "sql",
              "description": "Fill sparse time windows for a device path.",
              "insertText": "SELECT last_value(temperature)\nFROM root.factory.line1.device1\nWHERE time >= now() - 1h\nFILL(previous);",
              "parameters": [],
              "resultView": "timeChart"
            },
            {
              "id": "time-iotdb-latest",
              "label": "Latest values",
              "language": "sql",
              "description": "Read recent measurements from a hierarchy.",
              "insertText": "SELECT last_value(*)\nFROM root.factory.**;",
              "parameters": [],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "time-device-tree",
              "label": "Device tree",
              "description": "Keep storage group, device, and measurement hierarchy navigable."
            },
            {
              "id": "time-align-device",
              "label": "Align by device",
              "description": "Offer ALIGN BY DEVICE as a visible query option."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "iotdb.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}

{
  "schemaVersion": 1,
  "extensionId": "irodori.iotdb",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "iotdb.connector",
    "engine": "iotdb",
    "label": "IoTDB",
    "aliases": [
      "iotdb",
      "Apache IoTDB",
      "IoTDB"
    ],
    "defaultPort": 6667,
    "wire": "timeSeries",
    "module": "iotdb.driver",
    "features": [
      "metadata",
      "timeSeries",
      "timeBuckets",
      "latestValue",
      "queryTemplates",
      "visualization"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "hostPort",
        "connectionString"
      ],
      "defaultPort": 6667,
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "string",
          "profileField": "host",
          "required": true
        },
        {
          "id": "port",
          "label": "Port",
          "type": "number",
          "profileField": "port",
          "default": 6667
        },
        {
          "id": "database",
          "label": "Database",
          "type": "string",
          "profileField": "database"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "userPassword",
      "bearerToken",
      "kerberos",
      "clientCertificate",
      "customDriverOptions"
    ],
    "tls": "optional",
    "transports": "default",
    "optionNamespaces": [
      "timeSeries",
      "iotdb"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  },
  "experience": {
    "schemaVersion": 1,
    "domains": [
      "timeSeries"
    ],
    "inspiredBy": [
      "Apache IoTDB time-series hierarchy",
      "GROUP BY time",
      "ALIGN BY DEVICE",
      "FILL"
    ],
    "resultViews": [
      "timeChart",
      "table",
      "heatmap"
    ],
    "objectTypes": [
      "storageGroups",
      "devices",
      "measurements",
      "templates",
      "ttl"
    ],
    "workflows": [
      {
        "id": "time-device-query",
        "label": "Device aligned query",
        "description": "Compare measurements across devices.",
        "resultView": "timeChart",
        "templateIds": [
          "time-iotdb-group-by-device"
        ]
      },
      {
        "id": "time-gap-fill",
        "label": "Gap fill",
        "description": "Fill sparse telemetry windows for charting.",
        "resultView": "timeChart",
        "templateIds": [
          "time-iotdb-fill"
        ]
      },
      {
        "id": "time-latest",
        "label": "Latest telemetry",
        "description": "Inspect the newest values in a device subtree.",
        "resultView": "table",
        "templateIds": [
          "time-iotdb-latest"
        ]
      }
    ],
    "queryTemplates": [
      {
        "id": "time-iotdb-group-by-device",
        "label": "GROUP BY time aligned by device",
        "language": "sql",
        "description": "Aggregate measurements per device over the last hour.",
        "insertText": "SELECT avg(temperature)\nFROM root.factory.**\nWHERE time >= now() - 1h\nGROUP BY ([now() - 1h, now()), 1m)\nALIGN BY DEVICE;",
        "parameters": [],
        "resultView": "timeChart"
      },
      {
        "id": "time-iotdb-fill",
        "label": "Fill missing windows",
        "language": "sql",
        "description": "Fill sparse time windows for a device path.",
        "insertText": "SELECT last_value(temperature)\nFROM root.factory.line1.device1\nWHERE time >= now() - 1h\nFILL(previous);",
        "parameters": [],
        "resultView": "timeChart"
      },
      {
        "id": "time-iotdb-latest",
        "label": "Latest values",
        "language": "sql",
        "description": "Read recent measurements from a hierarchy.",
        "insertText": "SELECT last_value(*)\nFROM root.factory.**;",
        "parameters": [],
        "resultView": "table"
      }
    ],
    "inspectorHints": [
      {
        "id": "time-device-tree",
        "label": "Device tree",
        "description": "Keep storage group, device, and measurement hierarchy navigable."
      },
      {
        "id": "time-align-device",
        "label": "Align by device",
        "description": "Offer ALIGN BY DEVICE as a visible query option."
      }
    ]
  }
}
